# Aplicación
ENVIRONMENT=development
APP_PORT=8000
SECRET_KEY=cambiame_por_una_llave_super_secreta_de_32_caracteres_minimo

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/crm

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT
JWT_SECRET=supersecretkey
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_INBOUND_WEBHOOK_PATH=/webhook/consultorio-inbound
N8N_CALLBACK_SECRET=
N8N_BOT_STUB=false

# Bot
PUBLIC_BASE_URL=http://127.0.0.1:8000
BOT_ENABLED_DEFAULT=true
BOT_SUMMARY_REFRESH_EVERY_TURNS=6
BOT_RECENT_TURNS=2

# Meta / WhatsApp
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Invitaciones
INVITATION_EXPIRE_HOURS=48
